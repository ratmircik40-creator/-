<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Уклонение!</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { margin: 0; padding: 0; background-color: black; overflow: hidden; touch-action: none; }
        canvas { display: block; margin: 0 auto; background: black; border: 2px solid white; box-sizing: border-box; }
        #timer { position: absolute; top: 10px; left: 10px; color: white; font-family: monospace; font-size: 20px; font-weight: bold; }
    </style>
</head>
<body>
    <div id="timer">Время: 10</div>
    <canvas id="gameCanvas"></canvas>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand(); // Открываем на весь экран

        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        // Наша душа (игрок)
        let player = { x: canvas.width / 2 - 15, y: canvas.height - 60, size: 30, color: 'red' };
        
        // Препятствия (кости)
        let obstacles = [];
        let gameActive = true;
        let timeLeft = 10;
        
        // Управление касанием экрана
        window.addEventListener('touchstart', (e) => {
            let touchX = e.touches[0].clientX;
            if (touchX < canvas.width / 2) player.x -= 40; // Шаг влево
            else player.x += 40; // Шаг вправо
            
            // Ограничения экрана
            if (player.x < 0) player.x = 0;
            if (player.x + player.size > canvas.width) player.x = canvas.width - player.size;
        });

        // Создание костей
        function spawnObstacle() {
            let size = 40 + Math.random() * 60;
            let x = Math.random() * (canvas.width - size);
            obstacles.push({ x: x, y: -50, width: size, height: 20, speed: 5 + Math.random() * 5 });
        }

        // Таймер выживания
        let timerInterval = setInterval(() => {
            if (!gameActive) return;
            timeLeft--;
            document.getElementById('timer').innerText = "Время: " + timeLeft;
            if (timeLeft <= 0) {
                endGame("win");
            }
        }, 1000);

        setInterval(spawnObstacle, 400); // Как часто падают кости

        function endGame(result) {
            gameActive = false;
            clearInterval(timerInterval);
            // Отправляем результат боту и закрываем окно!
            tg.sendData(result); 
        }

        // Главный цикл игры
        function update() {
            if (!gameActive) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Рисуем душу
            ctx.fillStyle = player.color;
            ctx.fillRect(player.x, player.y, player.size, player.size);

            // Двигаем и рисуем препятствия
            ctx.fillStyle = 'white';
            for (let i = 0; i < obstacles.length; i++) {
                let obs = obstacles[i];
                obs.y += obs.speed;
                ctx.fillRect(obs.x, obs.y, obs.width, obs.height);

                // Проверка столкновения
                if (player.x < obs.x + obs.width &&
                    player.x + player.size > obs.x &&
                    player.y < obs.y + obs.height &&
                    player.y + player.size > obs.y) {
                    endGame("lose");
                }
            }
            requestAnimationFrame(update);
        }
        update();
    </script>
</body>
</html>
